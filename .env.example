OPENAI_API_KEY=your_api_key_here

# CORS：正式環境請設為前端網址，多個以逗號分隔；未設定時預設為 http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGINS=https://app.example.com

# Retriever k: 向量與 BM25 各取幾筆，建議 4～8（預設 6）
# VECTOR_RETRIEVER_K=6
# BM25_RETRIEVER_K=6

# Set to false/0/no to disable logging each query (question + sources + answer preview) to console
# LOG_QUERY_EVENTS=true

# RAG prompts（可調教回答風格與「找不到」指示；也可用 YAML 檔覆寫）
# RAG_SYSTEM_PROMPT=你是根據提供文件內容回答問題的助手…
# RAG_USER_TEMPLATE=以下為檢索到的內容：\n{context}\n\n問題：{input}\n請僅根據上述內容回答。
# RAG_NO_MATCH_INSTRUCTION=若提供的內容中沒有與問題相關的資訊，請明確回答「找不到相關內容」，不要猜測或編造。
# 選用：指定 YAML 檔路徑（相對專案根目錄或絕對路徑），從檔讀取 system / user_template / no_match_instruction
# RAG_PROMPTS_FILE=backend/prompts/rag_default.yaml